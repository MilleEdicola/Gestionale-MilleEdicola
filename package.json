import { createClient } from '@supabase/supabase-js'

export default async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).end()

  // Usa service key lato server per bypassare RLS
  const supabase = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL,
    process.env.SUPABASE_SERVICE_KEY || process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY
  )

  const { bolla, righe } = req.body
  if (!bolla || !righe) return res.status(400).json({ error: 'Dati mancanti' })

  try {
    // Salva bolla
    const { error: e1 } = await supabase.from('bolle_consegna').insert(bolla)
    if (e1) return res.status(500).json({ error: e1.message })

    // Salva righe
    const { error: e2 } = await supabase.from('bolle_righe').insert(righe)
    if (e2) return res.status(500).json({ error: e2.message })

    // Aggiorna anagrafica testate (upsert)
    for (const r of righe) {
      await supabase.from('testate').upsert({
        testata: r.testata,
        barcode: r.barcode,
        categoria: r.categoria,
        tipo_bolla: r.tipo_bolla,
        prezzo_copertina: r.prezzo_copertina,
        updated_at: new Date().toISOString()
      }, { onConflict: 'testata' })
    }

    return res.status(200).json({ ok: true })
  } catch (e) {
    return res.status(500).json({ error: e.message })
  }
}
